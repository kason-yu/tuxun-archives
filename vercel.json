{
  "version": 2,
  "builds": [
    {
      "src": "图寻/backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/图寻/world_map/geo_3.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/图寻/backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}